# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Local: postgresql://postgres:password@localhost:5432/ls_capital
# Supabase: get from project settings → Database → Connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/ls_capital"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── EMAIL (magic link login) ─────────────────────────────────────────────────
# Option 1: Gmail app password
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your@gmail.com"
EMAIL_SERVER_PASSWORD="gmail-app-password"
EMAIL_FROM="LS Capital <no-reply@lsfinance.com>"

# Option 2: For local dev — use Ethereal (https://ethereal.email)
# EMAIL_SERVER_HOST="smtp.ethereal.email"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER="ethereal-user@ethereal.email"
# EMAIL_SERVER_PASSWORD="ethereal-password"

# Option 3: Resend (production-ready, generous free tier)
# RESEND_API_KEY="re_xxxxxxxxxx"

# ─── AI EXTRACTION (Phase 1 AI feature) ───────────────────────────────────────
# Claude API key for deal extraction from listing text
ANTHROPIC_API_KEY="sk-ant-..."

